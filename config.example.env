# ============================================================================
# Piper TTS Training Configuration
#
# Copy this file to config.env and fill in your values:
#   cp config.example.env config.env
#
# Every value below needs to be set for your target language.
# ============================================================================

# --- Project Identity ---
# PROJECT_NAME: short slug, used for AWS resource names (security groups,
#   instance tags, systemd service). Use lowercase with hyphens.
PROJECT_NAME=sinhala-tts

# LANG_NAME: human-readable language name, used in log/status messages.
LANG_NAME=Sinhala

# LANG_LOCALE: Piper locale code, used in the exported model filename.
#   Format: <ISO 639-1>_<ISO 3166-1> (e.g. si_LK, ta_IN, bn_BD, sw_KE).
#   Must match a locale supported by piper-phonemize (espeak-ng).
LANG_LOCALE=si_LK

# INPUT_DATA_DIR: local path to your raw training data directory.
#   Must contain TextData.xlsx (filename|text mapping) and wavs/ directory.
INPUT_DATA_DIR=SinhalaTTSData

# --- S3 Configuration ---
S3_BUCKET=sinhala-tts-piper
S3_REGION=us-west-2
S3_DATA_PREFIX=training-data
S3_CHECKPOINT_PREFIX=checkpoints

# --- EC2 Configuration ---
# g6.xlarge (NVIDIA L4, 24GB VRAM) or g5.xlarge (NVIDIA A10G, 24GB VRAM)
# are good choices for medium-quality Piper training.
EC2_INSTANCE_TYPE=g6.xlarge
EC2_REGION=us-west-2
EC2_KEY_NAME=sinhala-tts-key
EC2_SPOT_MAX_PRICE=0.60
EC2_USE_SPOT=true

# --- Training Configuration ---
# PIPER_LANGUAGE: the ISO 639-1 language code passed to piper_train.
#   Must match a language supported by espeak-ng (used by piper-phonemize).
#   Common codes: si (Sinhala), ta (Tamil), bn (Bengali), hi (Hindi),
#   sw (Swahili), am (Amharic), my (Burmese), km (Khmer).
#   Full list: https://github.com/rhasspy/piper-phonemize
PIPER_LANGUAGE=si

PIPER_SAMPLE_RATE=22050
PIPER_BATCH_SIZE=32
PIPER_MAX_EPOCHS=6000
PIPER_CHECKPOINT_EPOCHS=25
PIPER_PRECISION=32

# PIPER_QUALITY: low/medium/high. Affects model size and voice quality.
#   low (~15MB) - fastest training, smaller model, lower quality
#   medium (~60MB) - good balance of quality and size
#   high (~100MB+) - best quality, needs more data and training time
PIPER_QUALITY=medium

# --- Base Checkpoint ---
# Fine-tuning from a related language is MUCH faster than from scratch.
# Pick the closest language available in the piper-checkpoints repo.
#
# Browse available checkpoints:
#   https://huggingface.co/datasets/rhasspy/piper-checkpoints
#
# Tips for choosing a base checkpoint:
#   - Same language family is best (e.g. Hindi for Sinhala, both Indo-Aryan)
#   - If no closely related language exists, any checkpoint still helps
#     (the model learns general speech patterns, not just the language)
#   - Match the quality level (use a medium checkpoint for medium training)
#   - The path format in the repo is: <lang>/<locale>/<speaker>/<quality>
#
# Common base checkpoints:
#   Hindi medium:   hi/hi_IN/rohan/medium    (good for South Asian languages)
#   English medium: en/en_US/lessac/medium    (widely available fallback)
#   German medium:  de/de_DE/thorsten/medium  (good for European languages)
BASE_CHECKPOINT_REPO=rhasspy/piper-checkpoints
BASE_CHECKPOINT_PATH=hi/hi_IN/rohan/medium
BASE_CHECKPOINT_LANG=hi_IN
BASE_CHECKPOINT_NAME=Hindi

# --- Local paths (on EC2) ---
# These rarely need changing unless you're using a custom AMI.
EC2_WORK_DIR=/home/ubuntu/training
EC2_DATA_DIR=/home/ubuntu/training/data
EC2_OUTPUT_DIR=/home/ubuntu/training/output
EC2_CHECKPOINT_DIR=/home/ubuntu/training/checkpoints

# --- Derived (do not edit) ---
ONNX_NAME=${LANG_LOCALE}-${PIPER_QUALITY}
