# S3 Configuration
S3_BUCKET=sinhala-tts-piper
S3_REGION=us-east-1
S3_DATA_PREFIX=training-data
S3_CHECKPOINT_PREFIX=checkpoints

# EC2 Configuration
EC2_INSTANCE_TYPE=g5.xlarge
EC2_REGION=us-east-1
EC2_AMI=ami-0c02fb55956c7d316  # Amazon Linux 2 (will be overridden by setup)
EC2_KEY_NAME=sinhala-tts-key
EC2_SPOT_MAX_PRICE=0.50

# Training Configuration
PIPER_LANGUAGE=si
PIPER_SAMPLE_RATE=22050
PIPER_BATCH_SIZE=32
PIPER_MAX_EPOCHS=3000
PIPER_CHECKPOINT_EPOCHS=100
PIPER_PRECISION=32
PIPER_QUALITY=medium

# Base checkpoint for fine-tuning (Hindi - closest Indo-Aryan language)
BASE_CHECKPOINT_REPO=rhasspy/piper-checkpoints
BASE_CHECKPOINT_PATH=hi/hi_IN/rohan/medium
BASE_CHECKPOINT_LANG=hi_IN

# Local paths (on EC2)
EC2_WORK_DIR=/home/ubuntu/training
EC2_DATA_DIR=/home/ubuntu/training/data
EC2_OUTPUT_DIR=/home/ubuntu/training/output
EC2_CHECKPOINT_DIR=/home/ubuntu/training/checkpoints
